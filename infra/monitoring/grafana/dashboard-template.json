{
  "dashboard": {
    "title": "TaskFlow - API Metrics",
    "uid": "taskflow-api",
    "timezone": "browser",
    "panels": [
      {
        "title": "Requests per Second",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])"
          }
        ],
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "title": "Error Rate (%)",
        "targets": [
          {
            "expr": "rate(errors_total[5m]) * 100"
          }
        ],
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "title": "Latency P95 (ms)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) * 1000"
          }
        ],
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "title": "Memory Usage (MB)",
        "targets": [
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024"
          }
        ],
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "title": "Request Count by Route",
        "targets": [
          {
            "expr": "topk(10, sum by (route) (rate(http_requests_total[5m])))"
          }
        ],
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 16
        }
      }
    ],
    "refresh": "10s",
    "schemaVersion": 26,
    "version": 1,
    "templating": {
      "list": []
    }
  },
  "overwrite": true
}
