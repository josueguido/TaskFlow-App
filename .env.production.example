# ============================================
# TaskFlow - Production Environment Overrides
# ============================================
# Apply on top of .env.example:
#   cp .env.example .env
#   cat .env.production.example >> .env
# ============================================

NODE_ENV=production
LOG_LEVEL=warn

# Database — NEVER use dev/staging DB
DB_HOST=db
DB_NAME=taskflow_production
DB_PASSWORD=change_me_production_db_password

# Auth — generate strong secrets: openssl rand -base64 32
JWT_SECRET=change_me_production_jwt_secret
JWT_REFRESH_SECRET=change_me_production_jwt_refresh_secret
SESSION_SECRET=change_me_production_session_secret
BCRYPT_SALT_ROUNDS=14

# Frontend URL pointing to production server
VITE_API_URL=https://yourdomain.com/api
CORS_ORIGIN=https://yourdomain.com

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me_production_grafana_password

# Webhooks
DISCORD_WEBHOOK_URL_CRITICAL=https://discord.com/api/webhooks/YOUR_PROD_WEBHOOK_ID/YOUR_PROD_WEBHOOK_TOKEN/slack
DISCORD_WEBHOOK_URL_WARNINGS=https://discord.com/api/webhooks/YOUR_PROD_WEBHOOK_ID/YOUR_PROD_WEBHOOK_TOKEN/slack
SLACK_WEBHOOK_URL_CRITICAL=https://hooks.slack.com/services/YOUR/PROD/WEBHOOK
