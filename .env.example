# ============================================
# TaskFlow - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env
# ============================================

# -----------------------------------
# App
# -----------------------------------
NODE_ENV=development
PORT=3003
APP_VERSION=latest

# -----------------------------------
# Database (PostgreSQL)
# -----------------------------------
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=taskflow
DB_HOST_PORT=5433
DB_CONTAINER_PORT=5432
# DATABASE_URL=postgresql://user:password@host:port/dbname  # Optional: used in production

# -----------------------------------
# JWT Authentication
# -----------------------------------
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------
# Security
# -----------------------------------
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# ALLOWED_EMAIL_DOMAINS=example.com,company.com  # Optional: restrict registration domains

# -----------------------------------
# Logging
# -----------------------------------
LOG_LEVEL=info

# -----------------------------------
# Docker Containers
# -----------------------------------
FRONTEND_CONTAINER_NAME=taskflow-frontend
BACKEND_CONTAINER_NAME=taskflow-backend
DB_CONTAINER_NAME=taskflow-db
PGADMIN_CONTAINER_NAME=taskflow-pgadmin

# -----------------------------------
# Docker Networks & Volumes
# -----------------------------------
TASKFLOW_NETWORK_NAME=taskflow_net
DB_VOLUME_NAME=taskflow_pgdata
PGADMIN_VOLUME_NAME=taskflow_pgadmin

# -----------------------------------
# pgAdmin
# -----------------------------------
PGADMIN_DEFAULT_EMAIL=admin@taskflow.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password  # MUST change for any non-local environment
PGADMIN_UID=5050 # MUST match the UID of the pgadmin user on the host machine for proper volume permissions
PGADMIN_GID=5050 # MUST match the GID of the pgadmin user on the host machine for proper volume permissions

# -----------------------------------
# Grafana (Monitoring)
# -----------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password  # MUST change for any non-local environment


# -----------------------------------
# Redis
# -----------------------------------
REDIS_CONTAINER_NAME=taskflow-redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_VOLUME_NAME=taskflow_redis

# -----------------------------------
# Frontend (Vite)
# -----------------------------------
VITE_API_URL=http://localhost:3003/api

# -----------------------------------
# Webhooks for Alerts (Discord & Slack)
# -----------------------------------
DISCORD_WEBHOOK_URL_CRITICAL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN/slack
DISCORD_WEBHOOK_URL_WARNINGS=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN/slack
SLACK_WEBHOOK_URL_CRITICAL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
