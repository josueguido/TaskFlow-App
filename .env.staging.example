# ============================================
# TaskFlow - Staging Environment Overrides
# ============================================
# Apply on top of .env.example:
#   cp .env.example .env
#   cat .env.staging.example >> .env
# ============================================

NODE_ENV=staging
LOG_LEVEL=debug

# Database — use a separate staging DB, never share with prod
DB_HOST=db
DB_NAME=taskflow_staging
DB_PASSWORD=change_me_staging_db_password

# Auth — generate strong secrets: openssl rand -base64 32
JWT_SECRET=change_me_staging_jwt_secret
JWT_REFRESH_SECRET=change_me_staging_jwt_refresh_secret
SESSION_SECRET=change_me_staging_session_secret

# Frontend URL pointing to staging server
VITE_API_URL=https://staging.yourdomain.com/api
CORS_ORIGIN=https://staging.yourdomain.com

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me_staging_grafana_password

# Webhooks
DISCORD_WEBHOOK_URL_CRITICAL=https://discord.com/api/webhooks/YOUR_STAGING_WEBHOOK_ID/YOUR_STAGING_WEBHOOK_TOKEN/slack
DISCORD_WEBHOOK_URL_WARNINGS=https://discord.com/api/webhooks/YOUR_STAGING_WEBHOOK_ID/YOUR_STAGING_WEBHOOK_TOKEN/slack
SLACK_WEBHOOK_URL_CRITICAL=https://hooks.slack.com/services/YOUR/STAGING/WEBHOOK
